# Copy to .env.local. Values below are the dev defaults; you don't need a local
# .env file just to run `npm run dev:api` — these are documented so production
# deployments can override them.

# --- Persistence ---
# Absolute path to the SQLite file. Defaults to <repo>/data/telemetry.db.
# Override in production or CI to use a writable ephemeral location.
# CLIMENCE_DB_PATH=/absolute/path/to/telemetry.db

# --- Auth ---
# Secret used to sign / verify JWT session tokens. REQUIRED in production.
# Generate with: openssl rand -base64 48
CLIMENCE_JWT_SECRET=change-me-in-production

# Token TTL (jsonwebtoken format: 12h, 7d, 30m, etc.)
CLIMENCE_JWT_EXPIRES_IN=12h

# --- Server ---
# HTTP + WebSocket port. Keep 3000 in dev to match the frontend API client.
# PORT=3000
