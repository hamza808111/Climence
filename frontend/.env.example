# Copy to .env.local. Vite only exposes variables prefixed with VITE_.

# --- Google Maps ---
# Required for the live map in <RiyadhGoogleMap />. Enable these in your GCP project:
#   - Maps JavaScript API
#   - Maps Tiles API
# Without this key the map falls back to a placeholder state.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- API location (optional) ---
# Override only if the backend runs somewhere other than localhost:3000.
# The shared constant API_BASE_URL is used by default.
# VITE_CLIMENCE_API_URL=http://localhost:3000
