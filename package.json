{
  "name": "climence",
  "version": "1.0.0",
  "private": true,
  "description": "Drone fleet air-quality monitoring for Riyadh: simulator, ingestion API, and live dashboard.",
  "workspaces": [
    "shared",
    "simulator",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,sim,ui -c cyan,magenta,green \"npm:dev:api\" \"npm:dev:sim\" \"npm:dev:ui\"",
    "dev:api": "npm run dev -w @climence/api",
    "dev:sim": "npm run dev -w @climence/simulator",
    "dev:ui": "npm run dev -w @climence/dashboard",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run typecheck && npm run lint && npm run test",
    "test:integration:api": "npm run test:integration -w @climence/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
